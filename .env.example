# --- Admin login ---
# Generate with: npm run hash-password -- "your-chosen-password"
ADMIN_PASSWORD_HASH=

# Random long string used to sign admin session cookies. Generate one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=db6358ff360ceed84b96df2a004472ea3d0a22e5df27e9c0e9df36d60c5e9773git 

# --- GitHub (lets the admin portal commit content changes) ---
# Fine-grained personal access token with Contents: Read and write
# permission, scoped to the repo below.
GITHUB_TOKEN=
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=your-repo-name
GITHUB_BRANCH=main
